<Window x:Class="Pagefold.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Pagefold"
        Icon="Resources/Pagefold.ico"
        Height="820"
        MinHeight="640"
        MinWidth="1080"
        Width="1320"
        Background="#10131C"
        Foreground="#F7F3EA"
        KeyDown="Window_KeyDown"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#10131C" />
        <SolidColorBrush x:Key="Panel" Color="#181B2A" />
        <SolidColorBrush x:Key="PanelSoft" Color="#202436" />
        <SolidColorBrush x:Key="Line" Color="#32384E" />
        <SolidColorBrush x:Key="Paper" Color="#F7F3EA" />
        <SolidColorBrush x:Key="Muted" Color="#B8B3C8" />
        <SolidColorBrush x:Key="Coral" Color="#FF7A7A" />
        <SolidColorBrush x:Key="Honey" Color="#F4C95D" />
        <SolidColorBrush x:Key="Lavender" Color="#AFA8FF" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="Padding" Value="14,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource Paper}" />
            <Setter Property="Background" Value="{StaticResource PanelSoft}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#2A2E43" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Coral}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#34283A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.035" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.035" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabButtonStyle" TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{StaticResource Muted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7,7,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1F2435" />
                                <Setter Property="Foreground" Value="{StaticResource Paper}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#24283B" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Coral}" />
                                <Setter Property="Foreground" Value="{StaticResource Paper}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.025" Duration="0:0:0.12" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.025" Duration="0:0:0.12" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.16" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.16" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#121520" />
            <Setter Property="Foreground" Value="{StaticResource Paper}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Foreground" Value="{StaticResource Paper}" />
            <Setter Property="Background" Value="{StaticResource PanelSoft}" />
            <Setter Property="BorderBrush" Value="{StaticResource Line}" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="7">
                                            <Grid>
                                                <ContentPresenter Margin="12,0,38,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                <TextBlock Text="v" Foreground="{StaticResource Coral}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource Coral}" />
                                                <Setter TargetName="Root" Property="Background" Value="#252A3E" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              Margin="12,0,38,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource PanelSoft}" BorderBrush="{StaticResource Coral}" BorderThickness="1" CornerRadius="7" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer Margin="4" MaxHeight="220">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Paper}" />
            <Setter Property="Background" Value="{StaticResource PanelSoft}" />
            <Setter Property="Padding" Value="12,8" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Paper}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Margin="0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="52" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track" Width="42" Height="24" HorizontalAlignment="Left" Background="#2A2E43" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="12">
                                <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="{StaticResource Muted}" HorizontalAlignment="Left" Margin="3,0,0,0" />
                            </Border>
                            <ContentPresenter Grid.Column="1" VerticalAlignment="Center" RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#42304A" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Coral}" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource Coral}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource Lavender}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="34" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="6" VerticalAlignment="Center" Background="#2A2E43" CornerRadius="3" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="{StaticResource Coral}" CornerRadius="3" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton IsTabStop="False" Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="20" Height="20">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{StaticResource Paper}" BorderBrush="{StaticResource Coral}" BorderThickness="2" CornerRadius="10" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
            <Grid Margin="16,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ToggleButton x:Name="LibraryTab" Style="{StaticResource TabButtonStyle}" Content="Library" Click="Tab_Click" />
                    <ToggleButton x:Name="ReaderTab" Style="{StaticResource TabButtonStyle}" Content="Reader" IsChecked="True" Click="Tab_Click" />
                    <ToggleButton x:Name="BookmarksTab" Style="{StaticResource TabButtonStyle}" Content="Bookmarks" Click="Tab_Click" />
                    <ToggleButton x:Name="HistoryTab" Style="{StaticResource TabButtonStyle}" Content="History" Click="Tab_Click" />
                    <ToggleButton x:Name="SettingsTab" Style="{StaticResource TabButtonStyle}" Content="Settings" Click="Tab_Click" />
                </StackPanel>

                <TextBlock x:Name="TitleText" Grid.Column="1" Margin="18,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Text="Ready for your next stack" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Open" Click="OpenFile_Click" ToolTip="Open comic file" />
                    <Button Content="Folder" Click="OpenFolder_Click" ToolTip="Scan library folder" />
                    <Button Content="Mark" Click="Bookmark_Click" ToolTip="Bookmark current page" />
                    <Button Content="Full" Click="Fullscreen_Click" ToolTip="Toggle fullscreen" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Background="{StaticResource Ink}">
            <Grid x:Name="ReaderPanel">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="150" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Shelf" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <ListBox x:Name="LibraryList" Grid.Row="1" DisplayMemberPath="DisplayName" MouseDoubleClick="LibraryList_MouseDoubleClick" />
                        <TextBlock Grid.Row="2" Text="Recent" FontSize="16" FontWeight="SemiBold" Margin="0,14,0,8" />
                        <ListBox x:Name="HistoryList" Grid.Row="3" DisplayMemberPath="DisplayName" MouseDoubleClick="HistoryList_MouseDoubleClick" />
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Background="#0E111A">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer x:Name="ImageScroll"
                                  Grid.Row="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="ImageScroll_PreviewMouseWheel"
                                  PreviewMouseDown="ImageScroll_PreviewMouseDown"
                                  PreviewMouseMove="ImageScroll_PreviewMouseMove"
                                  PreviewMouseUp="ImageScroll_PreviewMouseUp">
                        <StackPanel x:Name="ImageHost" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
                            <Image x:Name="PrimaryPage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
                            <Image x:Name="SecondaryPage" Margin="10,0,0,0" Stretch="Uniform" Visibility="Collapsed" RenderOptions.BitmapScalingMode="HighQuality" />
                        </StackPanel>
                    </ScrollViewer>

                    <wv2:WebView2 x:Name="PdfBrowser" Grid.Row="0" Visibility="Collapsed" />

                    <Grid x:Name="EmptyState" Grid.Row="0" Background="#0E111A">
                        <StackPanel Width="480" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Pagefold" TextAlignment="Center" FontSize="44" FontWeight="Bold" />
                            <TextBlock Text="Drop in a comic, scan a folder, and settle into the panels."
                                       Margin="0,12,0,0"
                                       Foreground="{StaticResource Muted}"
                                       FontSize="15"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                                <Button Content="Open File" Click="OpenFile_Click" />
                                <Button Content="Scan Folder" Click="OpenFolder_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#D8181B2A" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
                        <Grid Margin="14,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Content="Prev" Click="Previous_Click" />
                            <TextBlock x:Name="StatusText" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Text="Ready" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,10,0">
                                <Button Content="-" Click="ZoomOut_Click" ToolTip="Zoom out" />
                                <Button Content="Fit" Click="Fit_Click" ToolTip="Fit to window" />
                                <Button Content="+" Click="ZoomIn_Click" ToolTip="Zoom in" />
                                <ToggleButton x:Name="DoublePageToggle" Style="{StaticResource TabButtonStyle}" Content="2 Page" Click="ModeToggle_Click" />
                                <ToggleButton x:Name="MangaToggle" Style="{StaticResource TabButtonStyle}" Content="RTL" Click="ModeToggle_Click" />
                            </StackPanel>
                            <Button Grid.Column="3" Content="Next" Click="Next_Click" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="LibraryPanel" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock Text="Library" FontSize="30" FontWeight="Bold" />
                    <Button Content="Scan Folder" Margin="18,0,0,0" Click="OpenFolder_Click" />
                </StackPanel>
                <ListBox Grid.Row="1" ItemsSource="{Binding ElementName=LibraryList, Path=ItemsSource}" DisplayMemberPath="DisplayName" MouseDoubleClick="LibraryList_MouseDoubleClick" />
            </Grid>

            <Grid x:Name="BookmarksPanel" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Bookmarks" FontSize="30" FontWeight="Bold" Margin="0,0,0,16" />
                <ListBox x:Name="BookmarksList" Grid.Row="1" />
            </Grid>

            <Grid x:Name="HistoryPanel" Visibility="Collapsed" Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="History" FontSize="30" FontWeight="Bold" Margin="0,0,0,16" />
                <ListBox Grid.Row="1" ItemsSource="{Binding ElementName=HistoryList, Path=ItemsSource}" DisplayMemberPath="DisplayName" MouseDoubleClick="HistoryList_MouseDoubleClick" />
            </Grid>

            <Grid x:Name="SettingsPanel" Visibility="Collapsed" Margin="28">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Width="720" HorizontalAlignment="Left">
                        <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" Margin="0,0,0,20" />

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Reading" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Default mode" Foreground="{StaticResource Muted}" />
                                <ComboBox x:Name="DefaultModeCombo" Margin="0,6,0,14" SelectionChanged="Settings_Changed">
                                    <ComboBoxItem Content="Single Page" />
                                    <ComboBoxItem Content="Double Page" />
                                    <ComboBoxItem Content="Manga RTL" />
                                </ComboBox>
                                <CheckBox x:Name="ResumeLastPageCheck" Content="Resume last page when reopening a book" Foreground="{StaticResource Paper}" Margin="0,0,0,10" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                                <CheckBox x:Name="RememberWindowCheck" Content="Remember window size" Foreground="{StaticResource Paper}" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Controls" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Mouse wheel behavior" Foreground="{StaticResource Muted}" />
                                <ComboBox x:Name="MouseWheelCombo" Margin="0,6,0,14" SelectionChanged="Settings_Changed">
                                    <ComboBoxItem Content="Scroll, Ctrl+Wheel zooms" />
                                    <ComboBoxItem Content="Wheel zooms, Ctrl+Wheel scrolls" />
                                </ComboBox>
                                <TextBlock Text="Middle mouse drag pans the page. F11 toggles fullscreen." Foreground="{StaticResource Muted}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="Performance" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Page cache radius" Foreground="{StaticResource Muted}" />
                                <Slider x:Name="CacheRadiusSlider" Minimum="1" Maximum="10" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="Settings_Changed" />
                                <TextBlock x:Name="CacheRadiusText" Foreground="{StaticResource Muted}" Margin="0,4,0,12" />
                                <CheckBox x:Name="PreloadLargeBooksCheck" Content="Preload nearby pages in the background" Foreground="{StaticResource Paper}" Checked="Settings_Changed" Unchecked="Settings_Changed" />
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Storage" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock x:Name="StatePathText" Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Clear History" Click="ClearHistory_Click" />
                                    <Button Content="Clear Bookmarks" Click="ClearBookmarks_Click" />
                                    <Button Content="Clear Library" Click="ClearLibrary_Click" />
                                </StackPanel>
                                <TextBlock Text="State is saved under AppData, while generated build output stays out of git." Foreground="{StaticResource Muted}" Margin="0,14,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
